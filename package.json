  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:local": "node -r dotenv/config src/server.js dotenv_config_path=.env.local",
    "start:prod": "node -r dotenv/config src/server.js dotenv_config_path=.env.production",
    "dev:local": "node --watch -r dotenv/config src/server.js dotenv_config_path=.env.local",
    "db:sync:local": "node -r dotenv/config src/dbSync.js dotenv_config_path=.env.local",
    "db:sync:prod": "node -r dotenv/config src/dbSync.js dotenv_config_path=.env.production",
    "db:seed:local": "node -r dotenv/config src/seeders/seedDatabase.js dotenv_config_path=.env.local",
    "db:seed:prod": "node -r dotenv/config src/seeders/seedDatabase.js dotenv_config_path=.env.production",
    "db:unseed:local": "node -r dotenv/config src/seeders/unseedDatabase.js dotenv_config_path=.env.local",
    "db:unseed:prod": "node -r dotenv/config src/seeders/unseedDatabase.js dotenv_config_path=.env.production",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
