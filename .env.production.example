# Supabase PostgreSQL connection settings
# Use the Session pooler connection string from Supabase Project Settings > Database > Connect.
DATABASE_URL=postgres://postgres.your_project_ref:your_database_password@aws-0-your-region.pooler.supabase.com:5432/postgres
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_SCHEMA=public

# Optional pool settings
DATABASE_POOL_MAX=5
DATABASE_POOL_MIN=0
DATABASE_POOL_IDLE=10000
DATABASE_POOL_ACQUIRE=30000

# JWT / auth settings
JWT_SECRET=replace_with_a_secure_production_secret
JWT_EXPIRES_IN=1h
AUTH_COOKIE_NAME=token
COOKIE_SECURE=true
COOKIE_SAME_SITE=none
COOKIE_MAX_AGE=3600000

# Server settings
NODE_ENV=production
PORT=3000
CORS_ORIGIN=https://your-frontend-domain.com
